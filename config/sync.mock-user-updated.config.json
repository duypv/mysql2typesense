{
  "database": {
    "name": "app_mock",
    "excludeFields": [
      "password",
      "secret_token"
    ],
    "infix_string": true,
    "json_stringify": [
      "*IDs"
    ],
    "facet_fields": [
      "Status",
      "Type",
      "*Type",
      "Group",
      "*Group",
      "Category",
      "*ID",
      "*IDs",
      "*By",
      "Gender",
      "MedicalServiceID",
      "BYTType",
      "BYTGroup",
      "Integrated",
      "ExecPlace",
      "IsIVF",
      "PropertyApply",
      "Default",
      "BankAccountNumber",
      "BankAccountName",
      "Floor",
      "Services",
      "Consignment",
      "Unit",
      "WeekNumber"
    ]
  },
  "join_configs": [
    {
      "table": "ServicePriceHistory",
      "fields": [
        {
          "name": "ServiceID",
          "reference": "Service.ServiceID",
          "type": "int64",
          "async_reference": true
        }
      ]
    },
    {
      "table": "DrugPriceHistory",
      "fields": [
        {
          "name": "DrugID",
          "reference": "Drug.DrugID",
          "type": "int64",
          "async_reference": true
        }
      ]
    }
  ]
}
