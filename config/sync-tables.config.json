{
  "tables": [
    {
      "database": "app",
      "table": "users",
      "primaryKey": "id",
      "collection": "users",
      "batchSize": 500,
      "typesense": {
        "defaultSortingField": "created_at_ts",
        "enableNestedFields": true,
        "fields": [
          { "name": "id", "type": "string" },
          { "name": "email", "type": "string" },
          { "name": "full_name", "type": "string" },
          { "name": "status", "type": "string", "facet": true },
          { "name": "is_active", "type": "bool", "facet": true },
          { "name": "tags", "type": "string[]", "facet": true, "optional": true },
          { "name": "metadata", "type": "object", "optional": true },
          { "name": "created_at_ts", "type": "int64", "sort": true },
          { "name": "updated_at_ts", "type": "int64", "sort": true }
        ]
      },
      "transform": {
        "dropNulls": true,
        "fieldMappings": [
          { "source": "id", "target": "id", "type": "string" },
          { "source": "email", "target": "email", "type": "string" },
          { "source": "full_name", "target": "full_name", "type": "string" },
          { "source": "status", "target": "status", "type": "string" },
          { "source": "is_active", "target": "is_active", "type": "bool" },
          { "source": "tags", "target": "tags", "type": "string[]", "sourceFormat": "csv", "arraySeparator": ",", "optional": true },
          { "source": "metadata", "target": "metadata", "type": "object", "sourceFormat": "json", "optional": true },
          { "source": "created_at", "target": "created_at_ts", "type": "int64", "sourceFormat": "datetime", "timestampResolution": "seconds" },
          { "source": "updated_at", "target": "updated_at_ts", "type": "int64", "sourceFormat": "datetime", "timestampResolution": "seconds" }
        ]
      }
    },
    {
      "database": "app",
      "table": "products",
      "primaryKey": "id",
      "collection": "products",
      "batchSize": 500,
      "typesense": {
        "defaultSortingField": "updated_at_ts",
        "enableNestedFields": true,
        "fields": [
          { "name": "id", "type": "string" },
          { "name": "sku", "type": "string" },
          { "name": "name", "type": "string" },
          { "name": "price", "type": "float", "sort": true },
          { "name": "is_published", "type": "bool", "facet": true },
          { "name": "categories", "type": "string[]", "facet": true, "optional": true },
          { "name": "attributes", "type": "object", "optional": true },
          { "name": "created_at_ts", "type": "int64", "sort": true },
          { "name": "updated_at_ts", "type": "int64", "sort": true }
        ]
      },
      "transform": {
        "dropNulls": true,
        "fieldMappings": [
          { "source": "id", "target": "id", "type": "string" },
          { "source": "sku", "target": "sku", "type": "string" },
          { "source": "name", "target": "name", "type": "string" },
          { "source": "price", "target": "price", "type": "float" },
          { "source": "is_published", "target": "is_published", "type": "bool" },
          { "source": "categories", "target": "categories", "type": "string[]", "sourceFormat": "json", "optional": true },
          { "source": "attributes", "target": "attributes", "type": "object", "sourceFormat": "json", "optional": true },
          { "source": "created_at", "target": "created_at_ts", "type": "int64", "sourceFormat": "datetime", "timestampResolution": "seconds" },
          { "source": "updated_at", "target": "updated_at_ts", "type": "int64", "sourceFormat": "datetime", "timestampResolution": "seconds" }
        ]
      }
    }
  ]
}
