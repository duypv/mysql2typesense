# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=secret
DB_NAME=app

# Multi-table sync config
# If file is missing or tables[] is empty, service auto-discovers all tables in DB_NAME.
# You can also set {"database":{"name":"...","excludeFields":[...]}} in sync config
# and omit tables[] to auto sync full database with field exclusions.
SYNC_CONFIG_PATH=config/sync.config.json

# Initial sync behavior
SYNC_BATCH_SIZE=1000

# Typesense connection
TS_NODE_HOST=127.0.0.1
TS_NODE_PORT=8108
TS_NODE_PROTOCOL=http
TS_API_KEY=xyz

# Realtime behavior
CHECKPOINT_DRIVER=redis
CHECKPOINT_FILE=storage/checkpoints/binlog.json
CHECKPOINT_REDIS_KEY=mysql2typesense:binlog
REDIS_URL=redis://127.0.0.1:6379

# Monitoring / Dashboard
MONITORING_ENABLED=true
MONITORING_HOST=0.0.0.0
MONITORING_PORT=8080
MONITORING_AUTH_TOKEN=
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=500
LOG_LEVEL=info